{
  "name": "AI Cost Explorer",
  "description": "Deep dive into AI costs: spending breakdown by model, feature, team, and user; cost anomalies; and cache ROI. Requires AiResponse custom events and cost attribution tags (feature, team, user) from nr-ai-agent.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Cost Analysis",
      "description": "Cost breakdown, anomalies, and trends",
      "widgets": [
        {
          "title": "Total Cost This Week",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) AS 'Total Cost (USD)' FROM AiResponse SINCE 1 week ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 50 },
              { "alertSeverity": "CRITICAL", "value": 500 }
            ]
          }
        },
        {
          "title": "Avg Cost per Request",
          "layout": { "column": 4, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(`cost.totalUsd`) AS 'Avg Cost (USD)' FROM AiResponse SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Request Count This Week",
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) AS 'Requests' FROM AiResponse SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Cache Savings This Week",
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(cacheReadTokens) * 0.0001 AS 'Savings (USD)' FROM AiResponse SINCE 1 week ago"
              }
            ]
          }
        },

        {
          "title": "Cost Over Time",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.area" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse TIMESERIES 1 hour SINCE 7 days ago"
              }
            ],
            "yAxisLeft": { "zero": true }
          }
        },
        {
          "title": "Cost by Model",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.pie" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse FACET model SINCE 1 week ago"
              }
            ]
          }
        },

        {
          "title": "Cost by Feature",
          "layout": { "column": 1, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse FACET `ai.attribution.feature` SINCE 1 week ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Cost by Team",
          "layout": { "column": 5, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse FACET `ai.attribution.team` SINCE 1 week ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Cost by User",
          "layout": { "column": 9, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse FACET `ai.attribution.user` SINCE 1 week ago LIMIT 10"
              }
            ]
          }
        },

        {
          "title": "Input/Output Token Ratio by Model",
          "layout": { "column": 1, "row": 10, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(inputTokens) / average(outputTokens) FROM AiResponse FACET model TIMESERIES SINCE 7 days ago"
              }
            ]
          }
        },
        {
          "title": "Tokens Consumed by Type",
          "layout": { "column": 7, "row": 10, "width": 6, "height": 3 },
          "visualization": { "id": "viz.stacked-bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(inputTokens) AS 'Input', sum(outputTokens) AS 'Output', sum(thinkingTokens) AS 'Thinking', sum(cacheReadTokens) AS 'Cache Read', sum(cacheCreationTokens) AS 'Cache Creation' FROM AiResponse TIMESERIES SINCE 7 days ago"
              }
            ]
          }
        },

        {
          "title": "Top 10 Most Expensive Requests",
          "layout": { "column": 1, "row": 13, "width": 12, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT timestamp, model, `cost.totalUsd`, inputTokens, outputTokens, durationMs FROM AiResponse SINCE 1 week ago ORDER BY `cost.totalUsd` DESC LIMIT 10"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Cache Performance",
      "description": "Cache hit rates, savings, and efficiency metrics",
      "widgets": [
        {
          "title": "Cache Hit Rate",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentage(count(*), WHERE cacheReadTokens > 0) AS 'Cache Hit %' FROM AiResponse SINCE 1 week ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 20 },
              { "alertSeverity": "CRITICAL", "value": 5 }
            ]
          }
        },
        {
          "title": "Total Cache Savings",
          "layout": { "column": 4, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(cacheReadTokens) * 0.0001 AS 'Savings (USD)' FROM AiResponse SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Cache Creation Cost",
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(cacheCreationTokens) * 0.00025 AS 'Creation Cost (USD)' FROM AiResponse SINCE 1 week ago"
              }
            ]
          }
        },
        {
          "title": "Cache ROI",
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT (sum(cacheReadTokens) * 0.0001) / (sum(cacheCreationTokens) * 0.00025 + 0.001) AS 'ROI' FROM AiResponse SINCE 1 week ago"
              }
            ]
          }
        },

        {
          "title": "Cache Hit Rate Over Time",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.area" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentage(count(*), WHERE cacheReadTokens > 0) FROM AiResponse TIMESERIES 1 hour SINCE 7 days ago"
              }
            ]
          }
        },
        {
          "title": "Cache Savings vs Creation Cost",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.stacked-bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(cacheReadTokens) * 0.0001 AS 'Savings', sum(cacheCreationTokens) * 0.00025 AS 'Cost' FROM AiResponse TIMESERIES SINCE 7 days ago"
              }
            ]
          }
        },

        {
          "title": "Cache Performance by Model",
          "layout": { "column": 1, "row": 7, "width": 12, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT model, count(*) AS 'Requests', percentage(count(*), WHERE cacheReadTokens > 0) AS 'Hit %', sum(cacheReadTokens) * 0.0001 AS 'Savings', sum(cacheCreationTokens) * 0.00025 AS 'Creation Cost' FROM AiResponse FACET model SINCE 1 week ago"
              }
            ]
          }
        }
      ]
    }
  ]
}
