{
  "name": "AI Agent Workflows",
  "description": "Observability dashboard for agentic AI workloads, tracking task completion, anti-patterns, tool usage, delegation, and context management",
  "pages": [
    {
      "name": "Overview",
      "widgets": [
        {
          "title": "Task Completion Rate",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE ai.agent.task_success = true) FROM AiAgentTaskSummary SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.billboard"
          }
        },
        {
          "title": "Average Cost per Task",
          "layout": {
            "column": 4,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(ai.agent.cost_per_task_usd) FROM AiAgentTaskSummary SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.billboard"
          }
        },
        {
          "title": "Average Steps per Task",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(ai.agent.total_steps) FROM AiAgentTaskSummary SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.billboard"
          }
        },
        {
          "title": "Anti-Pattern Detection Count",
          "layout": {
            "column": 10,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AiAntiPattern SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.billboard"
          }
        },
        {
          "title": "Task Duration Distribution",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT histogram(ai.agent.task_duration_ms, 20) FROM AiAgentTaskSummary SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.histogram"
          }
        },
        {
          "title": "Cost per Task Over Time",
          "layout": {
            "column": 5,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(ai.agent.cost_per_task_usd) FROM AiAgentTaskSummary TIMESERIES SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.line"
          }
        },
        {
          "title": "Steps per Task Over Time",
          "layout": {
            "column": 9,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(ai.agent.total_steps) FROM AiAgentTaskSummary TIMESERIES SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.line"
          }
        },
        {
          "title": "Anti-Pattern Distribution",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AiAntiPattern FACET type SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.pie"
          }
        },
        {
          "title": "Recent Anti-Patterns",
          "layout": {
            "column": 5,
            "row": 7,
            "width": 8,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT timestamp, type, traceId, toolName, depthIndex FROM AiAntiPattern SINCE 24 hours ago LIMIT 20"
              }
            ]
          },
          "visualization": {
            "id": "viz.table"
          }
        },
        {
          "title": "Spinning Wheels Rate Over Time",
          "layout": {
            "column": 1,
            "row": 10,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE type = 'spinning_wheels') FROM AiAntiPattern TIMESERIES SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.line"
          }
        },
        {
          "title": "Tool Call Frequency",
          "layout": {
            "column": 5,
            "row": 10,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM Span WHERE spanType = 'tool_call' FACET toolName SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.bar"
          }
        },
        {
          "title": "Tool Success Rate by Tool",
          "layout": {
            "column": 9,
            "row": 10,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE success = true) FROM Span WHERE spanType = 'tool_call' FACET toolName SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.bar"
          }
        },
        {
          "title": "Slowest Tools",
          "layout": {
            "column": 1,
            "row": 13,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(durationMs) FROM Span WHERE spanType = 'tool_call' FACET toolName SINCE 24 hours ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.bar"
          }
        },
        {
          "title": "Delegation Depth Distribution",
          "layout": {
            "column": 5,
            "row": 13,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT histogram(ai.agent.delegation_depth, 5) FROM AiAgentTaskSummary SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.histogram"
          }
        },
        {
          "title": "Sub-Agent Cost Breakdown",
          "layout": {
            "column": 9,
            "row": 13,
            "width": 4,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(ai.agent.cost_per_task_usd) FROM AiAgentTaskSummary FACET ai.agent.name SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.bar"
          }
        },
        {
          "title": "Average Context Resets per Conversation",
          "layout": {
            "column": 1,
            "row": 16,
            "width": 12,
            "height": 3
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(ai.context.resets_count) FROM AiConversationSummary SINCE 7 days ago"
              }
            ]
          },
          "visualization": {
            "id": "viz.billboard"
          }
        }
      ]
    }
  ]
}
