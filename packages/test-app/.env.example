# Required — New Relic credentials
NEW_RELIC_LICENSE_KEY=your-license-key-here
NEW_RELIC_ACCOUNT_ID=your-account-id
NEW_RELIC_APP_NAME=ai-observatory-test

# Optional — AI provider API keys (skip to test only init/shutdown)
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_API_KEY=your-google-key

# Optional — Agent config overrides
NEW_RELIC_AI_LOG_LEVEL=debug
NEW_RELIC_AI_RECORD_CONTENT=true
