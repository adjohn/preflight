# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# Load priority: CLI flags > environment variables (.env or shell) > config file > defaults.
# Full config reference: example.config.js

# ── Required ──────────────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=your_license_key_nral
NEW_RELIC_ACCOUNT_ID=your_account_id

# ── User API key (required for team summary + deploy scripts) ─────────────────
NEW_RELIC_API_KEY=NRAK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Identity ──────────────────────────────────────────────────────────────────
# Falls back to $USER → git config user.name → "unknown" if unset.
NEW_RELIC_AI_MCP_DEVELOPER=jane_doe

NEW_RELIC_AI_TEAM_ID=my-team
NEW_RELIC_AI_PROJECT_ID=my-org/my-project
NEW_RELIC_AI_ORG_ID=my-org

# ── Budget caps (optional — remove to disable) ────────────────────────────────
NEW_RELIC_AI_SESSION_BUDGET_USD=5
NEW_RELIC_AI_DAILY_BUDGET_USD=20
NEW_RELIC_AI_WEEKLY_BUDGET_USD=100

# ── Optional overrides ────────────────────────────────────────────────────────
# NEW_RELIC_AI_MCP_LOG_LEVEL=debug        # debug | info | warn | error
# NEW_RELIC_AI_TRANSPORT=nr-events-api    # nr-events-api | otlp | both
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.nr-data.net
# OTEL_EXPORTER_OTLP_HEADERS=api-key=your_license_key_nral
